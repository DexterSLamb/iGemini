# 启动 web UI 前需要注入到环境的变量（start 脚本会自动做）。
# DeepSeek key 不放这里 —— 运行时从 ~/.config/deepseek/key（或 DEEPSEEK_API_KEY）读取。

ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
ANTHROPIC_MODEL=deepseek-v4-pro
ANTHROPIC_SMALL_FAST_MODEL=deepseek-v4-flash
# ANTHROPIC_API_KEY 在启动时从 ~/.config/deepseek/key 注入（若 401，改用 ANTHROPIC_AUTH_TOKEN）
