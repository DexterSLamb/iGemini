#!/bin/bash
# iGemini .pkg preinstall（root 执行）—— 安装前【全面停掉一切相关服务/进程】，保证干净（重）装/升级。
# 覆盖：本 .pkg 的 LaunchAgent、本项目旧脚本版 LaunchAgent、运行中的 iGemini 壳 app(WKWebView)、占 8888 的 node。
# 绝不动用户数据：~/.config（key）、~/.claude-igemini（隔离配置）。
U=$(/usr/bin/stat -f%Su /dev/console 2>/dev/null)
UID_=""
if [ -n "$U" ] && [ "$U" != "root" ]; then UID_=$(/usr/bin/id -u "$U"); fi

# 1) 停 LaunchAgents（本 .pkg 标签 + 本项目旧脚本版标签）
if [ -n "$UID_" ]; then
  for LBL in com.igemini.web com.cloudcli.deepseek; do
    /bin/launchctl bootout "gui/$UID_/$LBL" 2>/dev/null || true
  done
fi

# 2) 杀运行中的 iGemini 壳 app（WKWebView；不论装在 /Applications 还是 ~/Applications）
/usr/bin/pkill -x iGemini 2>/dev/null || true
/usr/bin/pkill -f "iGemini.app/Contents/MacOS" 2>/dev/null || true

# 3) 杀相关 node 服务 / 工具进程（含旧脚本版的 npm/node dist-server）
/usr/bin/pkill -f "start-web.sh" 2>/dev/null || true
/usr/bin/pkill -f "dist-server/server/index.js" 2>/dev/null || true

# 4) 兜底：仍占 127.0.0.1:8888 的 node 一律杀（确保端口释放给新服务）
for p in $(/usr/sbin/lsof -nP -iTCP:8888 -sTCP:LISTEN -t 2>/dev/null); do
  if /bin/ps -p "$p" -o comm= 2>/dev/null | grep -qi node; then /bin/kill -9 "$p" 2>/dev/null || true; fi
done

/bin/sleep 1   # 给进程退出/端口释放一点时间

# 注意：不在此删 /Applications/iGemini* —— payload 交给安装器铺/覆盖（build-pkg.sh 用递增版本号确保每次完整铺）。
# 教训：preinstall 删 payload + 同版本号重装 → 安装器以为"无变化"跳过铺文件，而文件已被删 → 壳 app 缺失。
# 故 preinstall 只负责【停服务 / 杀进程 / 释放端口】，绝不删 payload 目录。
exit 0
